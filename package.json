{
  "name": "cloudflare-workers-containers-hono-template",
  "description": "Hono-powered Cloudflare Worker that routes requests to a serverless Container backend (Workers Containers) via @cloudflare/containers.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env local --port 8002 --inspector-port 9231",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "REMOTE=1 drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun run prettier src/ --write",
    "bun:dev": "bun run --watch src/index.ts",
    "bun:start": "bun run src/index.ts",
    "bun:build": "bun build src/index.ts --compile --outfile server"
  },
  "dependencies": {
    "@antfu/eslint-config": "^6.7.1",
    "@d3avarja/try-catch": "^0.0.1",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "0.19.10",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.7",
    "jiti": "^2.6.1",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.2.0",
    "@deox/drizzle-d1-utils": "^0.0.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "wrangler": "^4.55.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
