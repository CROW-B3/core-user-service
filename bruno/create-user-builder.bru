meta {
  name: Create User Builder
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/user-builders
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "newuser@example.com",
    "orgId": "{{orgId}}",
    "role": "member"
  }
}
